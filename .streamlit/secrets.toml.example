# .streamlit/secrets.toml — Client Configuration
# ------------------------------------------------
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git (it is already in .gitignore).

# Client branding — shown in the page title and dashboard header
CLIENT_NAME = "Acme Corp"

# Password gate — remove or leave empty to disable
APP_PASSWORD = "changeme123"

# Default monthly revenue column in the client's CSV
# The app will pre-select this column in the Business Impact section
MONTHLY_COL = "MonthlyCharges"
