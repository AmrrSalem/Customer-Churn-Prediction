# .streamlit/secrets.toml — Client Configuration
# ------------------------------------------------
# Copy this to .streamlit/secrets.toml. Never commit to git.

# Branding
CLIENT_NAME = "Acme Corp"

# Password gate (remove or leave empty to disable)
APP_PASSWORD = "changeme123"

# Default monthly revenue column in the CSV
MONTHLY_COL = "MonthlyCharges"

# SMTP Email Alerts
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your-app@gmail.com"
SMTP_PASS = "your-app-password"
SMTP_FROM = "Churn Dashboard <your-app@gmail.com>"

# Supabase Cloud Storage (for persisting trained model bundles)
# Create a free project at https://supabase.com, then:
#   1. Create a Storage bucket named "model-bundles" (set to private)
#   2. Copy your project URL and anon/service_role key below
SUPABASE_URL    = "https://xxxx.supabase.co"
SUPABASE_KEY    = "eyJ..."
SUPABASE_BUCKET = "model-bundles"
